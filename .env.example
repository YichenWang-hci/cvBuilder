# Provider: gemini (free tier) | ollama (local free) | openai (paid API)
LLM_PROVIDER=gemini

# --- Gemini (recommended free) ---
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Ollama (100% free, runs on your Mac) ---
# Install: https://ollama.com  then: ollama pull llama3.2
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=llama3.2
# OLLAMA_HOST=http://localhost:11434

# --- OpenAI (requires separate API billing; ChatGPT Plus does NOT include this) ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

# Optional: "View Templates" button on home page (YouTube demo, etc.)
# TEMPLATES_VIDEO_URL=https://www.youtube.com/watch?v=YOUR_VIDEO_ID

# --- Figma (optional — for --validate / --fill-figma) ---
# Personal access token: Figma → Settings → Security → Personal access tokens
# File key: from URL https://www.figma.com/design/FILE_KEY/...
# FIGMA_ACCESS_TOKEN=figd_...
# FIGMA_FILE_KEY=your-file-key
# Optional: limit fill to one A4 frame (see templates/figma-template-map.yaml)
# FIGMA_TEMPLATE_FRAME=Resume Template
